# Top-level docker-compose env. Service-specific knobs live in
# services/<svc>/.env.example.

# --- Neo4j ------------------------------------------------------------------
NEO4J_PASSWORD=changeme

# --- Ingestion service & Celery --------------------------------------------
LOG_LEVEL=INFO
BATCH_SIZE=1000

# Celery worker concurrency (per-worker process count)
CELERY_WORKER_CONCURRENCY=1
# Max concurrent ingestion runs across the entire cluster (Redis semaphore).
# Independent of CELERY_WORKER_CONCURRENCY.
MAX_CONCURRENT_INGESTIONS=1
# Beat schedule (5-field cron). Empty disables the periodic Fundbox ingestion.
# Example: "0 */6 * * *" runs every 6 hours.
FUNDBOX_INGEST_CRON=

# --- Fundbox source database -----------------------------------------------
# Defaults to host.docker.internal so containers can reach MySQL on the host.
FUNDBOX_DB_HOST=host.docker.internal
FUNDBOX_DB_PORT=3306
FUNDBOX_DB_USER=root
FUNDBOX_DB_PASSWORD=
FUNDBOX_DB_NAME=fundbox-dev
FUNDBOX_CHUNK_SIZE=1000
