# Single source of truth for env vars across api / web / ingestion services.
# Copy to .env at the repo root. Both docker-compose and service-local dev
# reads pick up values from here.

# --- Host port mappings (docker-compose) -----------------------------------
# Override these if the defaults clash with something already running on the
# host. Container-internal ports are unchanged.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
# Primary ingress via nginx. The frontend and api services are not exposed directly.
NGINX_PORT=80

# --- Neo4j ------------------------------------------------------------------
NEO4J_PASSWORD=changeme

# --- Frontend (Next.js BFF) ------------------------------------------------
# Server-only URL the Next.js Route Handlers use to reach FastAPI. Inside the
# docker network the default (http://api:3000/v1) works; override when running
# the frontend container against a non-compose API (e.g. a deployed environment).
API_BASE_URL=http://api:3000/v1

# --- Authentication (Google SSO via Auth.js v5) ----------------------------
# Shared across api (verifies ID tokens) and web (runs the OAuth flow).
AUTH_ENABLED=true
# Google Cloud Console → Credentials → OAuth 2.0 Web application.
# Authorized redirect URI to register:
#   http://localhost/api/auth/callback/google  (via nginx on NGINX_PORT)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Optional — restrict sign-in to a single Google Workspace `hd`. Leave empty
# to allow any Google account. Enforced by the api.
AUTH_GOOGLE_HOSTED_DOMAIN=
# Auth.js session JWT signing key. Generate with: `openssl rand -base64 32`.
AUTH_SECRET=
# Public base URL of the app as served by nginx (must match Google's registered redirect URI).
NEXTAUTH_URL=http://localhost
# Comma-separated emails auto-promoted to role=admin on first login. This is
# how the FIRST admin gets in; subsequent users are created as role=first_time
# and must be granted access via the /admin/users page.
BOOTSTRAP_ADMIN_EMAILS=

# --- Ingestion service & Celery --------------------------------------------
LOG_LEVEL=INFO
BATCH_SIZE=1000

# Celery worker concurrency (per-worker process count)
CELERY_WORKER_CONCURRENCY=1
# Max concurrent ingestion runs across the entire cluster (Redis semaphore).
# Independent of CELERY_WORKER_CONCURRENCY.
MAX_CONCURRENT_INGESTIONS=1

# --- Fundbox source database (MySQL, optionally via SSH tunnel) -------------
# Set FUNDBOX_SSH_HOST to enable SSH tunnelling; leave empty for direct connect.
FUNDBOX_SSH_HOST=
FUNDBOX_SSH_PORT=
FUNDBOX_SSH_USER=
FUNDBOX_SSH_PASSWORD=
FUNDBOX_DB_HOST=
FUNDBOX_DB_PORT=
FUNDBOX_DB_USER=
FUNDBOX_DB_PASSWORD=
FUNDBOX_DB_NAME=
FUNDBOX_CHUNK_SIZE=
# Beat schedule (5-field cron, empty = disabled). Example: "0 */6 * * *"
FUNDBOX_INGEST_CRON=

# --- SpeedZone POS source database (MySQL, optionally via SSH tunnel) -------
SPEEDZONE_SSH_HOST=
SPEEDZONE_SSH_PORT=
SPEEDZONE_SSH_USER=
SPEEDZONE_SSH_PASSWORD=
SPEEDZONE_DB_HOST=
SPEEDZONE_DB_PORT=
SPEEDZONE_DB_USER=
SPEEDZONE_DB_PASSWORD=
SPEEDZONE_DB_NAME=
SPEEDZONE_CHUNK_SIZE=
SPEEDZONE_INGEST_CRON=

# --- Eko POS source database (MySQL, optionally via SSH tunnel) -------------
EKO_SSH_HOST=
EKO_SSH_PORT=
EKO_SSH_USER=
EKO_SSH_PASSWORD=
EKO_DB_HOST=
EKO_DB_PORT=
EKO_DB_USER=
EKO_DB_PASSWORD=
EKO_DB_NAME=
EKO_CHUNK_SIZE=
EKO_INGEST_CRON=
