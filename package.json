{
  "name": "hyperp-profile-unifier",
  "version": "0.1.0",
  "description": "Customer profile unification platform",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx scripts/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^6.19.2",
    "bullmq": "^5.71.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "fuzzball": "^2.2.3",
    "ioredis": "^5.10.1",
    "libphonenumber-js": "^1.12.41",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.2"
  }
}
