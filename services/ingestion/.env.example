# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Logging
LOG_LEVEL=INFO

# Ingestion tuning
BATCH_SIZE=500

# Celery / queue
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=1
MAX_CONCURRENT_INGESTIONS=1

# --- Fundbox source database (MySQL, optionally via SSH tunnel) -------------
# Set FUNDBOX_SSH_HOST to enable SSH tunnelling; leave empty for direct connect.
FUNDBOX_SSH_HOST=
FUNDBOX_SSH_PORT=
FUNDBOX_SSH_USER=
FUNDBOX_SSH_PASSWORD=
FUNDBOX_DB_HOST=
FUNDBOX_DB_PORT=
FUNDBOX_DB_USER=
FUNDBOX_DB_PASSWORD=
FUNDBOX_DB_NAME=
FUNDBOX_CHUNK_SIZE=
FUNDBOX_INGEST_CRON=

# --- SpeedZone POS source database (MySQL, optionally via SSH tunnel) -------
SPEEDZONE_SSH_HOST=
SPEEDZONE_SSH_PORT=
SPEEDZONE_SSH_USER=
SPEEDZONE_SSH_PASSWORD=
SPEEDZONE_DB_HOST=
SPEEDZONE_DB_PORT=
SPEEDZONE_DB_USER=
SPEEDZONE_DB_PASSWORD=
SPEEDZONE_DB_NAME=
SPEEDZONE_CHUNK_SIZE=
SPEEDZONE_INGEST_CRON=

# --- Eko POS source database (MySQL, optionally via SSH tunnel) -------------
EKO_SSH_HOST=
EKO_SSH_PORT=
EKO_SSH_USER=
EKO_SSH_PASSWORD=
EKO_DB_HOST=
EKO_DB_PORT=
EKO_DB_USER=
EKO_DB_PASSWORD=
EKO_DB_NAME=
EKO_CHUNK_SIZE=
EKO_INGEST_CRON=

# WhatsApp API (chrishubert/whatsapp-api compatible)
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_API_DEFAULT_SESSION=default
WHATSAPP_API_TIMEOUT_SECONDS=30

# Birthday greeting Celery task (disabled by default).
BIRTHDAY_TASK_ENABLED=false
BIRTHDAY_TASK_HOUR=8
BIRTHDAY_TASK_MINUTE=0
WHATSAPP_SOURCE_NUMBER=
BIRTHDAY_MESSAGE_TEMPLATE=Happy birthday, {name}! 🎉
