# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Logging
LOG_LEVEL=INFO

# Ingestion tuning
BATCH_SIZE=500

# Celery / queue
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=1
MAX_CONCURRENT_INGESTIONS=1

# --- Fundbox Consumer Backend source DB (MySQL, optionally via SSH tunnel) --
# Set FUNDBOX_CONSUMER_BACKEND_SSH_HOST to enable SSH tunnelling; leave empty for direct connect.
FUNDBOX_CONSUMER_BACKEND_SSH_HOST=
FUNDBOX_CONSUMER_BACKEND_SSH_PORT=
FUNDBOX_CONSUMER_BACKEND_SSH_USER=
FUNDBOX_CONSUMER_BACKEND_SSH_PASSWORD=
FUNDBOX_CONSUMER_BACKEND_DB_HOST=
FUNDBOX_CONSUMER_BACKEND_DB_PORT=
FUNDBOX_CONSUMER_BACKEND_DB_USER=
FUNDBOX_CONSUMER_BACKEND_DB_PASSWORD=
FUNDBOX_CONSUMER_BACKEND_DB_NAME=
FUNDBOX_CONSUMER_BACKEND_CHUNK_SIZE=
FUNDBOX_CONSUMER_BACKEND_INGEST_CRON=

# --- SpeedZone phppos source DB (MySQL, optionally via SSH tunnel) ----------
SPEEDZONE_PHPPOS_SSH_HOST=
SPEEDZONE_PHPPOS_SSH_PORT=
SPEEDZONE_PHPPOS_SSH_USER=
SPEEDZONE_PHPPOS_SSH_PASSWORD=
SPEEDZONE_PHPPOS_DB_HOST=
SPEEDZONE_PHPPOS_DB_PORT=
SPEEDZONE_PHPPOS_DB_USER=
SPEEDZONE_PHPPOS_DB_PASSWORD=
SPEEDZONE_PHPPOS_DB_NAME=
SPEEDZONE_PHPPOS_CHUNK_SIZE=
SPEEDZONE_PHPPOS_INGEST_CRON=

# --- Eko phppos source DB (MySQL, optionally via SSH tunnel) ----------------
EKO_PHPPOS_SSH_HOST=
EKO_PHPPOS_SSH_PORT=
EKO_PHPPOS_SSH_USER=
EKO_PHPPOS_SSH_PASSWORD=
EKO_PHPPOS_DB_HOST=
EKO_PHPPOS_DB_PORT=
EKO_PHPPOS_DB_USER=
EKO_PHPPOS_DB_PASSWORD=
EKO_PHPPOS_DB_NAME=
EKO_PHPPOS_CHUNK_SIZE=
EKO_PHPPOS_INGEST_CRON=

# WhatsApp API (chrishubert/whatsapp-api compatible)
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_API_DEFAULT_SESSION=default
WHATSAPP_API_TIMEOUT_SECONDS=30

# Birthday greeting Celery task (disabled by default).
BIRTHDAY_TASK_ENABLED=false
BIRTHDAY_TASK_HOUR=8
BIRTHDAY_TASK_MINUTE=0
WHATSAPP_SOURCE_NUMBER=
BIRTHDAY_MESSAGE_TEMPLATE=Happy birthday, {name}! 🎉
