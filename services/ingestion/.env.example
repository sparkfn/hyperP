# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Logging
LOG_LEVEL=INFO

# Ingestion tuning
BATCH_SIZE=500

# Celery / queue
# Worker concurrency = per-worker process count (Celery --concurrency).
# Max concurrent ingestions = cluster-wide cap enforced by a Redis semaphore
# inside the task itself; independent of worker concurrency. Default 1 means
# only one ingestion runs at a time even if multiple workers are deployed.
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=1
MAX_CONCURRENT_INGESTIONS=1
# Beat schedule for periodic Fundbox ingestion (5-field cron, empty = disabled).
# Example: "0 */6 * * *" runs every 6 hours.
FUNDBOX_INGEST_CRON=

# Fundbox source database (MySQL)
# In docker-compose this defaults to host.docker.internal so the container
# can reach a MySQL running on the host. For local non-docker dev use localhost.
FUNDBOX_DB_HOST=localhost
FUNDBOX_DB_PORT=3306
FUNDBOX_DB_USER=root
FUNDBOX_DB_PASSWORD=
FUNDBOX_DB_NAME=fundbox-dev
# Streaming chunk size for connector queries (rows per fetch). Lower = less
# memory, more round-trips; higher = more memory, fewer round-trips.
FUNDBOX_CHUNK_SIZE=1000

# WhatsApp API (chrishubert/whatsapp-api compatible)
# Multi-tenant WhatsApp Web REST API. Auth via static x-api-key header.
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_API_DEFAULT_SESSION=default
WHATSAPP_API_TIMEOUT_SECONDS=30

# Birthday greeting Celery task (disabled by default).
# Sends one WhatsApp message per unique phone to every active person whose
# preferred_dob (MM-DD) matches the current date. Set BIRTHDAY_TASK_ENABLED=true
# to register the daily beat schedule.
BIRTHDAY_TASK_ENABLED=false
BIRTHDAY_TASK_HOUR=8
BIRTHDAY_TASK_MINUTE=0
# WhatsApp session to send from (typically the source phone number / tenant id).
WHATSAPP_SOURCE_NUMBER=
# Message template; {name} is replaced with the recipient's full name.
BIRTHDAY_MESSAGE_TEMPLATE=Happy birthday, {name}! 🎉
